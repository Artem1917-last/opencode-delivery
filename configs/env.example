# OpenCode Delivery — Environment Configuration
# Скопируйте этот файл в .env и заполните значения

# ===========================================
# OpenCode Server (Basic Auth)
# ===========================================
OPENCODE_SERVER_USERNAME=admin
OPENCODE_SERVER_PASSWORD=CHANGE_ME_generate-14-char-password

# ===========================================
# Domain (для Let's Encrypt и Traefik)
# ===========================================
DOMAIN=opencode.example.com
LETSENCRYPT_EMAIL=admin@example.com
#OPENCODE_DOMAIN=opencode.example.com  # устарело, используйте DOMAIN

# ===========================================
# Timezone
# ===========================================
TZ=Europe/Moscow

# ===========================================
# AI Provider
# ===========================================
# antigravity — бесплатный (рекомендуется)
# gemini — Google AI (требует API key)
# custom — любой OpenAI-compatible
AI_PROVIDER=antigravity

# ===========================================
# Traefik Configuration
# ===========================================
# Traefik Dashboard доступен на порту 31415
# TRAEFIK_DASHBOARD=true

# ===========================================
# GitHub Integration (для DevOps Automator)
# ===========================================
#GITHUB_TOKEN=ghp_xxxxxxxxxxxx
#GITHUB_REPO=https://github.com/YOUR_ORG/your-repo

# ===========================================
# Google Workspace (опционально)
# ===========================================
#GOOGLE_CREDENTIALS_PATH=/data/google-credentials.json

# ===========================================
# Telegram (опционально)
# ===========================================
#TELEGRAM_API_ID=12345
#TELEGRAM_API_HASH=xxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Registry (опционально)
# ===========================================
#REGISTRY_IMAGE=registry.example.com/opencode:latest